<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:allowBackup="true"
        android:label="6 Years One Story ❤️"
        android:supportsRtl="true">

        <activity android:name=".activities.FinalSurpriseActivity"/>
        <activity android:name=".activities.ReasonsActivity"/>
        <activity android:name=".activities.GalleryActivity"/>
        <activity android:name=".activities.LoveLetterActivity"/>
        <activity android:name=".activities.BirthdayActivity"/>
